# Copy to .env (gitignored) — never commit .env
NIA_API_KEY=

# Nia API base (TryNia MCP docs — required for pipx nia-mcp-server)
NIA_API_URL=https://apigcp.trynia.ai/

# §5 Port map (Person 2 cache)
CACHE_API_URL=http://localhost:8000

# §2 Dashboard WebSocket (Person 3)
WS_PORT=8001

# Force a specific npm package via npx (all platforms). If unset: macOS/Linux use pipx
# nia-mcp-server; Windows defaults to npx nia-codebase-mcp@latest (pipx+Python stdio often Errno 22).
# NIA_MCP_PACKAGE=
# Windows only: set to 1 to use pipx nia-mcp-server (TryNia docs) instead of npx.
# NIA_WINDOWS_USE_PIPX=
# Windows only: npx package when using default Windows path (default: nia-codebase-mcp@latest).
# NIA_NPX_PACKAGE=
# Optional: npx executable token. Unix: default npx. Windows: passed after cmd /d /s /c (default npx).
# NIA_COMMAND=

# Rare: only if a fork of nia-codebase-mcp ignores NIA_API_KEY in env (upstream supports env).
# NIA_LEGACY_CLI_API_KEY=

# Optional: same string used during AVG_NIA_LATENCY_MS warmup (§2)
# NIA_WARMUP_QUERY=

# Optional: MCP client → Nia child tool timeout (ms). Default 300000 (5m).
# NIA_TOOL_TIMEOUT_MS=

# Optional: MCP initialize handshake timeout while pipx installs / starts nia-mcp-server (ms).
# SDK default is 60s; cold pipx often needs more. Default here: 300000 (5m).
# NIA_MCP_CONNECT_TIMEOUT_MS=

# Optional: HTTP timeouts to Person 2 (ms)
# CACHE_LOOKUP_TIMEOUT_MS=
# CACHE_INSERT_TIMEOUT_MS=